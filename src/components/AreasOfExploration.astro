---
import type { Dictionary } from '../i18n/ui';
import Card from './Card.astro';
import IconInclusion from './icons/IconInclusion.astro';
import IconDecentralised from './icons/IconDecentralised.astro';
import IconLanguage from './icons/IconLanguage.astro';
import IconNetwork from './icons/IconNetwork.astro';

interface Props {
	t: Dictionary;
}

const { t } = Astro.props;
const icons = [IconInclusion, IconDecentralised, IconLanguage, IconNetwork];
---

<section id="areas" class="areas">
	<div class="wrap">
		<p class="eyebrow eyebrow--lg">{t.areas.eyebrow}</p>
		<p class="areas__intro">{t.areas.intro}</p>
		<div class="card-grid">
			{t.areas.items.map((item, i) => {
				const Icon = icons[i];
				return (
					<Card item={item}>
						<Icon slot="icon" />
					</Card>
				);
			})}
		</div>
	</div>
</section>

<style>
	.areas {
		background: var(--color-bg-raised);
		border-block: 1px solid var(--color-border-soft);
	}

	.areas__intro {
		max-width: 68ch;
		color: var(--color-navy-soft);
	}
</style>
