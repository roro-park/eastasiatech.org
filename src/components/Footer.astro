---
import { legal } from '../i18n/legal';
import type { Dictionary } from '../i18n/ui';

interface Props {
	lang: string;
	t: Dictionary;
}

const { t } = Astro.props;
---

<footer class="site-footer">
	<div class="wrap site-footer__inner">
		<div class="site-footer__legal">
			<p class="site-footer__heading">{t.footer.legalHeading}</p>
			<p>
				{legal.companyName} {legal.companyNameKo}<br />
				{legal.registered}.<br />
				<span class="site-footer__no-wrap">{legal.registrationNo}.</span><br />
				{legal.address}.
			</p>
			<p class="site-footer__disclaimer">{legal.disclaimer}</p>
		</div>
		<div class="site-footer__contact">
			<p class="site-footer__heading">{t.footer.contactHeading}</p>
			<p>
				<a href={`mailto:${legal.contactEmail}`}>{legal.contactEmail}</a><br />
				{legal.contactDomain}
			</p>
		</div>
	</div>
	<div class="wrap site-footer__copyright">
		<p>{legal.copyright}</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--color-border-soft);
		padding-block: 3rem 1.5rem;
		font-size: 0.85rem;
		color: var(--color-navy-soft);
	}

	.site-footer__inner {
		display: flex;
		flex-wrap: wrap;
		gap: 2.5rem;
		justify-content: space-between;
	}

	.site-footer__legal {
		max-width: 56ch;
	}

	.site-footer__heading {
		font-weight: 600;
		color: var(--color-navy);
		text-transform: uppercase;
		font-size: 0.72rem;
		letter-spacing: 0.08em;
	}

	.site-footer__disclaimer {
		margin-top: 0.75em;
	}

	.site-footer__no-wrap {
		white-space: nowrap;
	}

	.site-footer__copyright {
		margin-top: 2rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border-soft);
	}

	.site-footer__copyright p {
		margin: 0;
	}
</style>
