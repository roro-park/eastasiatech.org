---
import type { Dictionary } from '../i18n/ui';

interface Props {
	t: Dictionary;
}

const { t } = Astro.props;
---

<section class="mission">
	<div class="wrap mission__inner">
		<p class="eyebrow eyebrow--lg">{t.mission.eyebrow}</p>
		<p>{t.mission.body}</p>
	</div>
</section>

<style>
	.mission {
		background: var(--color-bg-raised);
		border-block: 1px solid var(--color-border-soft);
	}

	.mission__inner {
		max-width: 78ch;
	}
</style>
