---
import { Image } from 'astro:assets';
import logoStacked from '../assets/logo/eati-stacked.png';
import type { Dictionary } from '../i18n/ui';

interface Props {
	t: Dictionary;
}

const { t } = Astro.props;
---

<section class="hero">
	<div class="wrap hero__inner">
		<div class="hero__copy">
			<p class="eyebrow">{t.hero.eyebrow}</p>
			<h1 class="display">{t.hero.headline}</h1>
			<p class="hero__intro">{t.hero.intro}</p>
			<a class="button" href="#contact">{t.hero.cta}</a>
		</div>
		<div class="hero__mark">
			<Image src={logoStacked} alt="East Asia Technology Institute" width={280} />
		</div>
	</div>
</section>

<style>
	.hero__inner {
		display: flex;
		align-items: center;
		gap: 3rem;
		flex-wrap: wrap-reverse;
	}

	.hero__copy {
		flex: 1 1 420px;
		max-width: 640px;
	}

	.hero__intro {
		font-size: 1.05rem;
		color: var(--color-navy-soft);
		max-width: 52ch;
	}

	.hero__mark {
		flex: 0 0 auto;
		margin-inline: auto;
	}

	.hero__mark :global(img) {
		display: block;
		width: min(240px, 40vw);
		height: auto;
	}

	.button {
		display: inline-block;
		margin-top: 1rem;
		padding: 0.7em 1.5em;
		background: var(--color-navy);
		color: var(--color-bg-raised);
		text-decoration: none;
		border-radius: 2px;
		font-weight: 600;
		font-size: 0.92rem;
	}

	.button:hover {
		background: var(--color-blue);
	}
</style>
